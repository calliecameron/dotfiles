#!/bin/bash

set -eu

source "${PACKAGE_SOURCE_DIR}/env.sh"

if ! command -v nix &>/dev/null; then
    wget https://releases.nixos.org/nix/nix-2.31.2/install
    echo '078e2ffeddf6a9c1f22adf41458ccc46a58bb26911a9e01579645314f9982994  install' >checksum
    sha256sum -c checksum
    chmod u+x install
    ./install --daemon --no-modify-profile --yes
    source "${PACKAGE_SOURCE_DIR}/env.sh"
fi

# Update nix
sudo bash -l -c "nix-channel --add 'https://channels.nixos.org/${DOTFILES_NIXPKGS_CHANNEL}' nixpkgs"
sudo bash -l -c 'nix-channel --update'
sudo bash -l -c "nix-env --install --file '<nixpkgs>' --attr cacert nix"
sudo cp /nix/var/nix/profiles/default/lib/systemd/system/nix-daemon.service /lib/systemd/system
sudo cp /nix/var/nix/profiles/default/lib/systemd/system/nix-daemon.socket /lib/systemd/system
sudo rm /etc/systemd/system/nix-daemon.service
sudo rm /etc/systemd/system/nix-daemon.socket
sudo ln -s /lib/systemd/system/nix-daemon.service /etc/systemd/system/nix-daemon.service
sudo ln -s /lib/systemd/system/nix-daemon.socket /etc/systemd/system/nix-daemon.socket
sudo systemctl daemon-reload
sudo systemctl restart nix-daemon

mkdir -p "${DOTFILES_NIX_PROFILE_DIR}"

nix-channel --add "https://github.com/nix-community/home-manager/archive/release-${DOTFILES_NIXPKGS_VERSION}.tar.gz" home-manager
nix-channel --add "https://channels.nixos.org/${DOTFILES_NIXPKGS_CHANNEL_UNSTABLE}" nixpkgs-unstable
# Pinning commit because of https://github.com/nix-community/nixGL/issues/217;
# otherwise doesn't work on nvidia
nix-channel --add 'https://github.com/nix-community/nixGL/archive/a662aa32d0991aff5e8b7ef0905d0dc2d9da5eef.tar.gz' nixgl

nix-channel --update

"${PACKAGE_SOURCE_DIR}/bin/dotfiles-nix-install-from-channel" home-manager home-manager
"${PACKAGE_SOURCE_DIR}/bin/dotfiles-nix-install-from-channel" nixgl auto.nixGLDefault

mkdir -p "${HOME}/.config/home-manager"
sed "s|@@@@@1@@@@@|${USER}|g" <"${PACKAGE_SOURCE_DIR}/home-template.nix" |
    sed "s|@@@@@2@@@@@|${HOME}|g" |
    sed "s|@@@@@3@@@@@|${DOTFILES_HOME_MANAGER}|g" |
    sed "s|@@@@@4@@@@@|${DOTFILES_LOCAL_HOME_MANAGER}|g" >"${HOME}/.config/home-manager/home.nix"

if [ ! -f "${DOTFILES_LOCAL_HOME_MANAGER}" ]; then
    cat >"${DOTFILES_LOCAL_HOME_MANAGER}" <<EOF
{ ... }:
{

}
EOF
fi

home-manager switch
