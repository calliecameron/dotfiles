#!/bin/bash

set -eu

function cleanup-root() {
    sudo bash -l -c "nix-env --profile '/nix/var/nix/profiles/per-user/root/${1}' --delete-generations '${DOTFILES_NIX_GC_AFTER}'"
}

cleanup-root profile
cleanup-root channels

function cleanup-user() {
    nix-env --delete-generations --profile "${1}" "${DOTFILES_NIX_GC_AFTER}"
}

cleanup-user "${DOTFILES_NIX_PROFILE}"
cleanup-user "${DOTFILES_NIX_CHANNELS}"

nix-store --gc
