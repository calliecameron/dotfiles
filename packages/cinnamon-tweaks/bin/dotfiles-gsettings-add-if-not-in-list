#!/usr/bin/env python3

import argparse
import ast
import subprocess
from typing import cast


def non_empty_string(s: str) -> str:
    if not s:
        raise argparse.ArgumentTypeError("must be non-empty")
    return s


def gsettings_get_list(schema: str, key: str) -> list[str]:
    s = subprocess.check_output(
        ["gsettings", "get", schema, key],
        encoding="utf-8",
    ).strip()
    if s == "@as []":
        s = "[]"
    return cast("list[str]", ast.literal_eval(s))


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Add a value to a gsettings list, but only if it isn't "
        "there already",
    )
    parser.add_argument("schema", type=non_empty_string)
    parser.add_argument("key", type=non_empty_string)
    parser.add_argument("value", type=non_empty_string)

    args = parser.parse_args()

    l = gsettings_get_list(args.schema, args.key)

    if args.value not in l:
        l.append(args.value)

    subprocess.call(["gsettings", "set", args.schema, args.key, str(l)])


if __name__ == "__main__":
    main()
