#!/bin/bash

set -eu

chmod go-rwx "${HOME}"

sudo apt-get update
sudo apt-get upgrade
sudo apt-get dist-upgrade

sudo apt-get -y install apt-transport-https curl git nano ncurses-term \
    netcat-openbsd screen tmux tree zsh zsh-doc

if dotfiles-linux-variant main; then
    # Mint 22
    sudo apt-get purge --auto-remove celluloid hypnotix mintchat pix rhythmbox \
        samba-common samba-common-bin smbclient thunderbird \
        transmission-common transmission-gtk

    sudo apt-get -y install apparmor-profiles apparmor-utils \
        fonts-crosextra-caladea fonts-crosextra-carlito inotify-tools \
        laptop-detect powertop sqlite3 ttf-ancient-fonts \
        ttf-mscorefonts-installer ubuntu-restricted-extras xclip

    # Stop other services launching SSH agents
    sudo systemctl --global disable gcr-ssh-agent.socket gcr-ssh-agent.service gpg-agent-ssh.socket
    systemctl --user disable gcr-ssh-agent.socket gcr-ssh-agent.service gpg-agent-ssh.socket
    cp /etc/xdg/autostart/gnome-keyring-ssh.desktop "${HOME}/.config/autostart/gnome-keyring-ssh.desktop"
    echo 'Hidden=true' >>"${HOME}/.config/autostart/gnome-keyring-ssh.desktop"

    sudo rm -f /etc/sudoers.d/0pwfeedback
    rm -f "${HOME}/.local/share/applications/webapp-OnlineChat4519.desktop"
    fc-cache
else
    dotfiles-echo-red "Unknown Linux variant."
    exit 1
fi

exit 0
