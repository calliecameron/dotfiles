#!/bin/bash

set -eu

export PATH="${PACKAGE_SOURCE_DIR}/bin:${PATH}"

IGNORED_DEPS=''
if dotfiles-package-installed laptop-mode-tools; then
    IGNORED_DEPS='power-profiles-daemon-'
fi

sudo apt-get update
sudo apt-get -y --no-remove install kde-plasma-desktop kwin-addons okular \
    plasma-workspace-wayland sddm- unattended-upgrades- ${IGNORED_DEPS}

function install-config() {
    cp "${PACKAGE_SOURCE_DIR}/${1}" "${HOME}/.config/${1}"
}

# Settings

KDEGLOBALS="${HOME}/.config/kdeglobals"
kwriteconfig5 --file "${KDEGLOBALS}" --group KDE --key SingleClick --type bool false
kwriteconfig5 --file "${KDEGLOBALS}" --group KDE --key ScrollbarLeftClickNavigatesByPage --type bool false

kwriteconfig5 --file "${HOME}/.config/ksmserverrc" --group General --key loginMode emptySession

kwriteconfig5 --file "${HOME}/.config/kscreenlockerrc" --group Daemon --key LockGrace 0

KWINRC="${HOME}/.config/kwinrc"
kwriteconfig5 --file "${KWINRC}" --group Effect-windowview --key BorderActivateAll 9
kwriteconfig5 --file "${KWINRC}" --group TabBox --key LayoutName thumbnail_grid

kwriteconfig5 --file "${HOME}/.config/systemsettingsrc" --group systemsettings_sidebar_mode --key HighlightNonDefaultSettings --type bool true

kwriteconfig5 --file "${HOME}/.config/klipperrc" --group General --key KeepClipboardContents --type bool false

KRUNNERRC="${HOME}/.config/krunnerrc"
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key PowerDevilEnabled --type bool false
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key appstreamEnabled --type bool false
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key baloosearchEnabled --type bool false
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key browserhistoryEnabled --type bool false
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key browsertabsEnabled --type bool false
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key desktopsessionsEnabled --type bool false
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key org.kde.windowedwidgetsEnabled --type bool false
kwriteconfig5 --file "${KRUNNERRC}" --group Plugins --key webshortcutsEnabled --type bool false

DOLPHINRC="${HOME}/.config/dolphinrc"
kwriteconfig5 --file "${DOLPHINRC}" --group General --key RememberOpenedTabs --type bool false
kwriteconfig5 --file "${DOLPHINRC}" --group ContentDisplay --key UseShortRelativeDates --type bool false

kwriteconfig5 --file "${HOME}/.config/konsolerc" --group KonsoleWindow --key RememberWindowSize --type bool false

KWRITERC="${HOME}/.config/kwriterc"
kwriteconfig5 --file "${KWRITERC}" --group General --key 'Show welcome view for new window' --type bool false
kwriteconfig5 --file "${KWRITERC}" --group 'KTextEditor Document' --key 'On-The-Fly Spellcheck' --type bool true
kwriteconfig5 --file "${KWRITERC}" --group 'KTextEditor Document' --key 'Show Spaces' 1
kwriteconfig5 --file "${KWRITERC}" --group 'KTextEditor Renderer' --key 'Word Wrap Marker' --type bool true
kwriteconfig5 --file "${KWRITERC}" --group 'KTextEditor View' --key 'Auto Brackets' --type bool false
# Yes that's 'shoe' not 'show'
kwriteconfig5 --file "${KWRITERC}" --group 'KTextEditor View' --key 'Shoe Line Ending Type in Statusbar' --type bool true

# Taskbar and desktop

APPLET_FILE='plasma-org.kde.plasma.desktop-appletsrc'
ACTIVITY="$(kactivities-cli --bare --current-activity)"
WALLPAPER="$(kreadconfig5 --file "${HOME}/.config/${APPLET_FILE}" --group Containments --group 1 --group Wallpaper --group org.kde.image --group General --key Image)"
ICON_APPLETS=''

function add-panel-icon() {
    local APPLET_NUMBER="${1}"
    local DIR
    DIR="$(dirname "${2}")"
    local DESKTOP_FILE
    DESKTOP_FILE="$(basename "${2}")"

    sed "s|@@@@@1@@@@@|${APPLET_NUMBER}|g" <"${PACKAGE_SOURCE_DIR}/appletsrc-icon" |
        sed "s|@@@@@2@@@@@|${HOME}|g" |
        sed "s|@@@@@3@@@@@|${DESKTOP_FILE}|g" |
        sed "s|@@@@@4@@@@@|${DIR}|g"
    echo

    ICON_APPLETS="${ICON_APPLETS}${APPLET_NUMBER};"
}

{
    sed "s|@@@@@1@@@@@|${ACTIVITY}|g" <"${PACKAGE_SOURCE_DIR}/appletsrc-part1"
    echo

    if [ -n "${WALLPAPER}" ]; then
        sed "s|@@@@@1@@@@@|${WALLPAPER}|g" <"${PACKAGE_SOURCE_DIR}/appletsrc-wallpaper"
        echo
    fi

    cat "${PACKAGE_SOURCE_DIR}/appletsrc-part2"
    echo

    add-panel-icon 30 '/usr/share/applications/org.kde.konsole.desktop'
    add-panel-icon 31 '/usr/share/applications/org.kde.dolphin.desktop'

    if dotfiles-package-installed chrome; then
        add-panel-icon 32 "${HOME}/.local/share/applications/google-chrome.desktop"
    fi

    if dotfiles-package-installed emacs; then
        add-panel-icon 33 "${HOME}/.local/share/applications/emacs-daemon.desktop"
    fi

    sed "s|@@@@@1@@@@@|${ICON_APPLETS}|g" <"${PACKAGE_SOURCE_DIR}/appletsrc-part3"
} >"${PACKAGE_INSTALL_DIR}/${APPLET_FILE}"

cp "${PACKAGE_INSTALL_DIR}/${APPLET_FILE}" "${HOME}/.config/${APPLET_FILE}"

# Notifications

install-config 'devicenotifications.notifyrc'
install-config 'kcm_touchpad.notifyrc'
install-config 'kwrited.notifyrc'
install-config 'networkmanagement.notifyrc'
install-config 'plasma_workspace.notifyrc'
install-config 'powerdevil.notifyrc'

# File associations

install-config 'kde-mimeapps.list'

if ! dotfiles-package-installed emacs; then
    xdg-mime default org.kde.kwrite.desktop \
        text/english \
        text/plain \
        text/x-makefile \
        text/x-c++hdr \
        text/x-c++src \
        text/x-chdr \
        text/x-csrc \
        text/x-java \
        text/x-moc \
        text/x-pascal \
        text/x-tcl \
        text/x-tex \
        application/x-shellscript \
        text/x-c \
        text/x-c++ \
        text/markdown
fi

# Bookmarks

BOOKMARKS="${HOME}/.local/share/user-places.xbel"

if [ -e "${BOOKMARKS}" ]; then
    dotfiles-hide-kde-bookmark "${BOOKMARKS}" Documents
    dotfiles-hide-kde-bookmark "${BOOKMARKS}" Music
    dotfiles-hide-kde-bookmark "${BOOKMARKS}" Pictures
    dotfiles-hide-kde-bookmark "${BOOKMARKS}" Videos
fi

# Launchers

xdg-desktop-menu install --novendor "${PACKAGE_SOURCE_DIR}/dotfiles-toggle-kde-theme.desktop"

# Keybindings

SHORTCUTSRC="${HOME}/.config/kglobalshortcutsrc"

function bind-key() {
    local GROUP="${1}"
    local KEY="${2}"
    local BINDING="${3}"
    kwriteconfig5 --file "${SHORTCUTSRC}" --group "${GROUP}" --key "${KEY}" "${BINDING},${BINDING},${KEY}"
}

function unbind-key() {
    bind-key "${1}" "${2}" 'none'
}

function launcher-key() {
    local DESKTOP_FILE="${1}"
    local NAME="${2}"
    local BINDING="${3}"
    kwriteconfig5 --file "${SHORTCUTSRC}" --group "${DESKTOP_FILE}" --key '_k_friendly_name' "${NAME}"
    kwriteconfig5 --file "${SHORTCUTSRC}" --group "${DESKTOP_FILE}" --key '_launch' "${BINDING},none,${NAME}"
}

bind-key 'ksmserver' 'Lock Session' 'Ctrl+Alt+L'
bind-key 'kwin' 'Walk Through Windows of Current Application (Reverse)' 'Alt+¬'
bind-key 'kwin' 'Window Operations Menu' 'Alt+Space'
unbind-key 'kwin' 'Expose'
unbind-key 'kwin' 'ExposeAll'
unbind-key 'kwin' 'ExposeClass'
unbind-key 'kwin' 'Switch to Desktop 1'
unbind-key 'kwin' 'Switch to Desktop 2'
unbind-key 'kwin' 'Switch to Desktop 3'
unbind-key 'kwin' 'Switch to Desktop 4'
unbind-key 'kwin' 'Window Quick Tile Bottom'
unbind-key 'kwin' 'Window Quick Tile Left'
unbind-key 'kwin' 'Window Quick Tile Right'
unbind-key 'kwin' 'Window Quick Tile Top'
unbind-key 'plasmashell' 'show dashboard'
bind-key 'mediacontrol' 'nextmedia' 'Ctrl+Alt+.'
bind-key 'mediacontrol' 'previousmedia' 'Ctrl+Alt+\,'
bind-key 'mediacontrol' 'playpausemedia' 'Ctrl+Alt+Space'
bind-key 'org.kde.krunner.desktop' '_launch' 'Alt+F2'

launcher-key 'emacs-daemon.desktop' 'GNU Emacs (Daemon Mode)' 'Ctrl+Alt+E'
launcher-key 'google-chrome.desktop' 'Google Chrome' 'Ctrl+Alt+B'
launcher-key 'thunderbird.desktop' 'Thunderbird' 'Ctrl+Alt+M'
launcher-key 'vlc.desktop' 'VLC' 'Ctrl+Alt+P'
launcher-key 'org.kde.dolphin.desktop' 'Dolphin' 'Ctrl+Alt+H'
launcher-key 'gnucash.desktop' 'GnuCash' 'Ctrl+Alt+G'
launcher-key 'org.gnome.Calculator.desktop' 'Calculator' 'Ctrl+Alt+C'
launcher-key 'codium.desktop' 'VSCodium' 'Ctrl+Alt+V'
launcher-key 'discord.desktop' 'Discord' 'Ctrl+Alt+D'
# shellcheck disable=1003
launcher-key 'dotfiles-toggle-kde-theme.desktop' 'Toggle Theme' 'Ctrl+Alt+\\'

KXKBRC="${HOME}/.config/kxkbrc"
kwriteconfig5 --file "${KXKBRC}" --group Layout --key Options 'caps:ctrl_modifier'
kwriteconfig5 --file "${KXKBRC}" --group Layout --key ResetOldOptions --type bool true

# Theme

dotfiles-set-kde-theme dark
