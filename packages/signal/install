#!/bin/bash

set -eu

sudo true

wget -O- https://updates.signal.org/desktop/apt/keys.asc | gpg --dearmor |
    sudo tee /usr/share/keyrings/signal-desktop-keyring.gpg >/dev/null
echo 'deb [arch=amd64 signed-by=/usr/share/keyrings/signal-desktop-keyring.gpg] https://updates.signal.org/desktop/apt xenial main' |
    sudo tee /etc/apt/sources.list.d/signal.list >/dev/null

sudo apt-get update
sudo apt-get -y install signal-desktop

sed "s|/opt/Signal/signal-desktop|${PACKAGE_SOURCE_DIR}/bin/signal-desktop|g" \
    <'/usr/share/applications/signal-desktop.desktop' \
    >"${HOME}/.local/share/applications/signal-desktop.desktop"

xdg-desktop-icon install --novendor "${HOME}/.local/share/applications/signal-desktop.desktop"

cp "${HOME}/.local/share/applications/signal-desktop.desktop" "${HOME}/.config/autostart"
