#!/bin/bash
# Unmount an SSH path easily

set -eu

function usage() {
    echo "Usage: $(basename "${0}") dir" >&2
    exit 1
}

test -z "${1:-}" && usage
test "${#}" -gt 1 && usage

DIR="${DOTFILES_SSH_MOUNT_DIR}/${1}"

if [ ! -d "${DIR}" ]; then
    echo "No such mount: ${DIR}" >&2
    exit 1
fi

fusermount -u "${DIR}"
rmdir "${DIR}"
rmdir --ignore-fail-on-non-empty "${DOTFILES_SSH_MOUNT_DIR}"
