#!/bin/bash
# Mount an SSH path easily

set -eu

function usage() {
    echo "Usage: $(basename "${0}") [user@]host [dir]" >&2
    exit 1
}

test -z "${1:-}" && usage
test "${#}" -gt 2 && usage

HOST="${1}"
DIR="${2:-}"

NICEDIR="${DIR////_}"

MOUNTPOINT="${DOTFILES_SSH_MOUNT_DIR}/${HOST}_${NICEDIR}"

if [ -e "${MOUNTPOINT}" ]; then
    echo 'Already mounted' >&2
    exit 0
fi

mkdir -p "${MOUNTPOINT}"

if ! sshfs "${HOST}:${DIR}" "${MOUNTPOINT}"; then
    rmdir "${MOUNTPOINT}"
fi

exit 0
