#!/bin/bash

set -eu

sudo apt-get update
sudo apt-get -y install cryptsetup gnupg pinentry-gtk2 libgcrypt20-dev

VERSION='2.13'

if [ ! -e "${PACKAGE_INSTALL_DIR}/bin/tomb" ]; then
    mkdir -p "${PACKAGE_INSTALL_DIR}/bin"
    BUILD_DIR="$(mktemp -d)"
    cd "${BUILD_DIR}"
    curl 'https://keybase.io/jaromil/pgp_keys.asc' | gpg --import
    wget "https://files.dyne.org/tomb/releases/Tomb-${VERSION}.tar.gz"
    wget "https://files.dyne.org/tomb/releases/Tomb-${VERSION}.tar.gz.sha"
    wget "https://files.dyne.org/tomb/releases/Tomb-${VERSION}.tar.gz.asc"
    sha512sum -c "Tomb-${VERSION}.tar.gz.sha"
    gpg --verify "Tomb-${VERSION}.tar.gz.asc" "Tomb-${VERSION}.tar.gz"
    tar -xf "Tomb-${VERSION}.tar.gz"
    cd "Tomb-${VERSION}"
    cd extras/kdf-keys
    make
    cp -t "${PACKAGE_INSTALL_DIR}/bin" tomb-kdb-hexencode tomb-kdb-pbkdf2 \
        tomb-kdb-pbkdf2-gensalt tomb-kdb-pbkdf2-getiter
    cp ../../tomb "${PACKAGE_INSTALL_DIR}/bin"
    cd
    rm -rf "${BUILD_DIR}"
fi
