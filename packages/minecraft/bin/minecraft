#!/bin/bash

set -eu

function usage() {
    echo "Usage: $(basename "${0}")" >&2
    exit 1
}

test "${#}" -gt 0 && usage

if [ "${XDG_SESSION_TYPE}" = 'wayland' ]; then
    DISPLAY_ARGS='--hostwayland --satellite'
else
    DISPLAY_ARGS='--hostdisplay'
fi

# shellcheck disable=2086
x11docker \
    --backend=podman \
    --fallback=no \
    --rootless \
    --xc \
    --gpu \
    --lang \
    --network \
    --pulseaudio=host \
    ${DISPLAY_ARGS} \
    --name=minecraft \
    --env HOME=/minecraft \
    --env LC_ALL=en_GB.UTF-8 \
    --share minecraft \
    -- \
    --hostname minecraft \
    --cap-add sys_chroot \
    "--umask=$(umask)" \
    -- \
    minecraft
