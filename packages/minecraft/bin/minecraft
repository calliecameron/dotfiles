#!/bin/bash

set -eu

function usage() {
    echo "Usage: $(basename "${0}")" >&2
    exit 1
}

test "${#}" -gt 0 && usage

x11docker \
    --backend=podman \
    --fallback=no \
    --rootless \
    --xc \
    --gpu \
    --lang \
    --network \
    --pulseaudio=host \
    --hostdisplay \
    --name=minecraft \
    --env HOME=/minecraft \
    --env LC_ALL=en_GB.UTF-8 \
    --share minecraft \
    -- \
    --hostname minecraft \
    --cap-add sys_chroot \
    "--umask=$(umask)" \
    -- \
    minecraft
