#!/bin/bash

set -eu

sudo true

if ! command -v google-chrome &>/dev/null; then
    wget -O- https://dl.google.com/linux/linux_signing_key.pub | sudo apt-key add -
    wget -O "${PACKAGE_INSTALL_DIR}/chrome.deb" https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
    sudo apt-get -y --fix-broken install "${PACKAGE_INSTALL_DIR}/chrome.deb"
    rm "${PACKAGE_INSTALL_DIR}/chrome.deb"
fi

sed 's|/usr/bin/google-chrome-stable|google-chrome-stable|g' \
    <"/usr/share/applications/google-chrome.desktop" \
    >"${HOME}/.local/share/applications/google-chrome.desktop"

xdg-desktop-icon install --novendor "${HOME}/.local/share/applications/google-chrome.desktop"
