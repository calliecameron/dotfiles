#!/bin/bash

set -eu

EAT_VERSION='c8d54d649872bfe7b2b9f49ae5c2addbf12d3b99'

# We keep a local copy of these for machines where Emacs isn't installed
dotfiles-clone-or-update-repo 'https://github.com/calliecameron/term-cmd' "${PACKAGE_INSTALL_DIR}/term-cmd" 'main'
dotfiles-clone-or-update-repo 'https://github.com/calliecameron/term-alert' "${PACKAGE_INSTALL_DIR}/term-alert" 'main'
dotfiles-clone-or-update-repo 'https://codeberg.org/akib/emacs-eat' "${PACKAGE_INSTALL_DIR}/eat" "${EAT_VERSION}"

dotfiles-home-link "${PACKAGE_INSTALL_DIR}/eat/terminfo" "${HOME}/.terminfo"

if dotfiles-can-sudo; then
    TARGET='/etc/sudoers.d/terminfo'
    sudo cp "${PACKAGE_SOURCE_DIR}/sudoers" "${TARGET}"
    sudo chown root:root "${TARGET}"
    sudo chmod ug=r "${TARGET}"
    sudo chmod o-rwx "${TARGET}"
fi
