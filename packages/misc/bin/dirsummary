#!/usr/bin/env python3

import argparse
import os
from collections import defaultdict
from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from collections.abc import Callable


def non_empty_string(s: str) -> str:
    if not s:
        raise argparse.ArgumentTypeError("must be non-empty")
    return s


def pretty_size(num: float) -> str:
    for unit in ("B", "KiB", "MiB", "GiB", "TiB"):
        if num < 1024.0:  # noqa: PLR2004
            return f"{num:3.1f} {unit}"
        num /= 1024.0
    return "{num:3.1f} {unit}"


def main() -> None:
    parser = argparse.ArgumentParser(
        description="List the number and total size of each type of file in a "
        "directory tree",
    )
    parser.add_argument("dir", type=non_empty_string, nargs="?", default=".")

    args = parser.parse_args()

    if not os.path.isdir(args.dir):
        parser.error("dir must be a directory")

    special_cases: list[tuple[Callable[[str], bool], str]] = [
        (lambda f: f.lower() == "makefile", "Makefile"),
    ]
    out: dict[str, tuple[int, int]] = defaultdict(lambda: (0, 0))

    def add_file(ext: str, size: int) -> None:
        count, total = out[ext]
        out[ext] = (count + 1, total + size)

    def get_ext(f: str) -> str:
        for pred, ext in special_cases:
            if pred(f):
                return ext
        if "." not in f:
            return ""
        return os.path.splitext(f)[1][1:]

    for path, _, files in os.walk(args.dir):
        for f in files:
            add_file(get_ext(f), os.path.getsize(os.path.join(path, f)))

    for key in sorted(out):
        count, total = out[key]
        if not key:
            key = "No extension"  # noqa: PLW2901
        print(f"{key}: {count} file(s), {pretty_size(total)}")


if __name__ == "__main__":
    main()
