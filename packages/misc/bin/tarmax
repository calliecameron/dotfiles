#!/bin/bash
# Tar with maximum compression

set -eu

function usage() {
    echo "Usage: $(basename "${0}") infile [outfile]" >&2
    exit 1
}

test -z "${1:-}" && usage
INFILE="${1}"

if [ -n "${2:-}" ]; then
    OUTFILE="${2}"
else
    OUTFILE="${INFILE}.tar.xz"
fi

test "${#}" -gt 2 && usage

XZ_OPT=-9 tar cJf "${OUTFILE}" "${INFILE}"
