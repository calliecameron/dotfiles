#!/usr/bin/env python3

import argparse
import pathlib
import shutil
import sys


def non_empty_string(s: str) -> str:
    if not s:
        raise argparse.ArgumentTypeError("must be non-empty")
    return s


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Move each file in a list to the corresponding file in another "
        "list",
    )
    parser.add_argument("src_list_file", type=non_empty_string)
    parser.add_argument("dest_list_file", type=non_empty_string)

    args = parser.parse_args()

    src_file = pathlib.Path(args.src_list_file)
    dest_file = pathlib.Path(args.dest_list_file)

    if not src_file.is_file() or not dest_file.is_file():
        parser.error("args must be existing files")

    with src_file.open(encoding="utf-8") as f:
        src = [line.strip() for line in f]

    with dest_file.open(encoding="utf-8") as f:
        dest = [line.strip() for line in f]

    if len(src) != len(dest):
        sys.stderr.write("List lengths differ\n")
        sys.exit(1)

    for s, d in zip(src, dest, strict=True):
        if not s or not d:
            sys.stderr.write(f"Found empty line, skipping: src '{s}', dest '{d}'\n")
            continue
        if pathlib.Path(s).exists():
            shutil.move(s, d)


if __name__ == "__main__":
    main()
