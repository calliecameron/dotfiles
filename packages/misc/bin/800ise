#!/bin/bash
# Shrink all images specified on the command line, in place, to be 800x600

set -eu

function usage() {
    echo "Usage: $(basename "${0}") files..." >&2
    exit 1
}

test -z "${1:-}" && usage

function do-shrink() {
    convert "${1}" -resize 800 "${1}"
}

while (($#)); do
    do-shrink "${1}"
    shift
done
