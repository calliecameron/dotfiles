#!/bin/bash
# List all the file extensions in the specified folder, or the current folder if
# none specified

set -eu

function usage() {
    echo "Usage: $(basename "${0}") [dir]" >&2
    exit 1
}

test "${#}" -gt 1 && usage

if [ -z "${1:-}" ]; then
    LOCATION='.'
else
    LOCATION="${1}"
fi

find "${LOCATION}" -type f -name '*.*' | sed 's|.*\.||' | LC_ALL=C sort -u
