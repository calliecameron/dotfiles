#!/bin/bash

set -eu

function usage() {
    echo "Usage: $(basename "${0}")" >&2
    exit 1
}

test "${#}" -gt 0 && usage

if [ -n "${DOTFILES_NO_LOGOUT_NEEDED_CHECK:-}" ]; then
    exit 0
fi

if [ -e "${DOTFILES_NEEDS_LOGOUT}" ]; then
    dotfiles-echo-yellow 'Log out and log in again to set everything up correctly.'
fi

exit 0
