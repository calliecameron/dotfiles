#!/bin/bash

set -eu

function usage() {
    echo "Usage: $(basename "${0}")" >&2
    exit 1
}

test "${#}" -gt 0 && usage

if [ -n "${DOTFILES_NO_PACKAGE_LOCK:-}" ]; then
    exit 0
fi

if ! rmdir "${DOTFILES_PACKAGE_MUTEX}"; then
    dotfiles-echo-yellow "Failed to release package lock."
fi

exit 0
