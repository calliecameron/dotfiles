#!/bin/bash

set -eu

function usage() {
    echo "Usage: $(basename "${0}") package_name" >&2
    exit 1
}

test -z "${1:-}" && usage
test "${#}" -gt 1 && usage
PACKAGE_NAME="${1}"

[[ "${PACKAGE_NAME}" != *'/'* ]] &&
    [[ "${PACKAGE_NAME}" != *' '* ]] &&
    [[ "${PACKAGE_NAME}" != *':'* ]] &&
    [[ "${PACKAGE_NAME}" != *$'\n'* ]]
