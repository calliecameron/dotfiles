#!/bin/bash
# Display a message in blue the next time an interactive shell is started (use
# instead of echo, which won't be seen in env scripts).

set -eu

function usage() {
    echo "Usage: $(basename "${0}") msg..." >&2
    exit 1
}

test -z "${1:-}" && usage

echo "${@}" >>"${DOTFILES_PACKAGE_MESSAGES_FILE}"
