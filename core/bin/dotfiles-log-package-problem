#!/bin/bash
# Display a message in orange the next time an interactive shellis started (use
# instead of echo, which won't be seen in env scripts).

set -eu

function usage() {
    echo "Usage: $(basename "${0}") msg..." >&2
    exit 1
}

test -z "${1:-}" && usage

echo "${@}" >>"${DOTFILES_PACKAGE_PROBLEMS_FILE}"
